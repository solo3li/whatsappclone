@model IEnumerable<Message>
@{
    ViewData["Title"] = "Message Logs";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Message Logs</h1>
</div>

<form method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="searchTerm" class="form-control" placeholder="Search by content or sender..." value="@ViewBag.SearchTerm">
        <button class="btn btn-outline-secondary" type="submit">Search</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover table-sm">
        <thead>
            <tr>
                <th>Sender</th>
                <th>Chat ID</th>
                <th>Content</th>
                <th>Timestamp</th>
                <th>Type</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var msg in Model)
            {
                <tr>
                    <td>@msg.Sender?.Name (@msg.Sender?.Email)</td>
                    <td>@msg.ChatId</td>
                    <td>@msg.Content</td>
                    <td>@msg.Timestamp.ToString("g")</td>
                    <td>@msg.MessageType</td>
                </tr>
            }
        </tbody>
    </table>
</div>
