@model User
@{
    ViewData["Title"] = "User Profile - " + Model.Name;
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">User Profile</h1>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body text-center">
                <img src="@(string.IsNullOrEmpty(Model.AvatarUrl) ? "https://via.placeholder.com/150" : Model.AvatarUrl)" alt="avatar" class="rounded-circle mb-3" width="150" height="150" />
                <h3>@Model.Name</h3>
                <p class="text-muted">@Model.Email</p>
                <p>@Model.Status</p>
                <hr />
                <p>Created: @Model.CreatedAt.ToString("g")</p>
                <p>Last Seen: @Model.LastSeen?.ToString("g")</p>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                Statuses
            </div>
            <div class="card-body">
                @if (Model.Statuses.Any())
                {
                    <div class="row">
                        @foreach (var status in Model.Statuses)
                        {
                            <div class="col-md-4 mb-3">
                                <div class="card">
                                    <img src="@status.ImageUrl" class="card-img-top" alt="status" />
                                    <div class="card-body">
                                        <p class="card-text small">@status.Caption</p>
                                        <p class="text-muted extra-small">@status.CreatedAt.ToString("g")</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p>No active statuses.</p>
                }
            </div>
        </div>
    </div>
</div>
