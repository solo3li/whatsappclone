@model IEnumerable<User>
@{
    ViewData["Title"] = "User Management";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Users</h1>
</div>

<div class="table-responsive">
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Avatar</th>
                <th>Name</th>
                <th>Email</th>
                <th>Status</th>
                <th>Online</th>
                <th>Last Seen</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>
                        <img src="@(string.IsNullOrEmpty(user.AvatarUrl) ? "https://via.placeholder.com/40" : user.AvatarUrl)" alt="avatar" class="rounded-circle" width="40" height="40" />
                    </td>
                    <td>@user.Name</td>
                    <td>@user.Email</td>
                    <td>@user.Status</td>
                    <td>
                        <span class="badge @(user.IsOnline ? "bg-success" : "bg-secondary")">
                            @(user.IsOnline ? "Online" : "Offline")
                        </span>
                    </td>
                    <td>@user.LastSeen?.ToString("g")</td>
                    <td>
                        <div class="btn-group">
                            <a asp-action="UserProfile" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">View</a>
                            <form asp-action="ToggleOnline" asp-route-id="@user.Id" method="post" style="display:inline">
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Toggle Online</button>
                            </form>
                            <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" style="display:inline" onsubmit="return confirm('Are you sure?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
